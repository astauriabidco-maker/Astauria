{
    "name": "astauria-cms",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run dev:api\" \"npm run dev:admin\"",
        "dev:api": "cd apps/api && npm run start:dev",
        "dev:admin": "cd apps/admin && npm run dev",
        "build": "npm run build:api && npm run build:admin",
        "build:api": "cd apps/api && npm run build",
        "build:admin": "cd apps/admin && npm run build",
        "generate": "cd apps/api && npm run generate",
        "db:migrate": "cd apps/api && npx prisma migrate dev",
        "db:seed": "cd apps/api && npx prisma db seed"
    },
    "devDependencies": {
        "concurrently": "^8.2.0"
    }
}