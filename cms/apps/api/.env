# Astauria CMS - Environment Variables

# Database - Use your PostgreSQL connection string
# Option 1: Local PostgreSQL (brew install postgresql)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/astauria_cms?schema=public"

# Option 2: Supabase (free tier)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"

# Option 3: Railway
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/railway"

# For now, using SQLite as fallback (change to PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="astauria-cms-super-secret-key-change-in-production-2024"

# Admin Frontend URL (for CORS)
ADMIN_URL="http://localhost:5173"

# Server
PORT=3001
